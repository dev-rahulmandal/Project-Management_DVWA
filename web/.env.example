# Prolane web - fake training values only.
# Copy to web/.env.local before running: cp web/.env.example web/.env.local
# Run `npm run dev` from the web/ directory.

# Shared with api - must match api/.env
DATABASE_PATH=../prolane.db
JWT_SECRET=summer2023
JWT_ISSUER=prolane-api

# Session cookie signing (web-only)
SESSION_SECRET=fake-session-secret-for-training-only

# Used in login route handler to verify Origin header
WEB_ORIGIN=http://localhost:8082,http://prolane.test:8082

# Server-side calls from Next.js to the api service
INTERNAL_API_ORIGIN=http://localhost:8081

# Browser-side calls from the SPA to the api origin (inlined at build). Uses a
# non-loopback host so a proxy (Burp) can see api traffic (browsers bypass the
# proxy for localhost). Add a hosts entry: 127.0.0.1  prolane.test api.prolane.test
NEXT_PUBLIC_API_ORIGIN=http://api.prolane.test:8081

# Face: 0 = challenge (default, hides the /secure/* twins), 1 = lab. Keep in sync
# with api/.env. Leave at 0 for a public deployment.
VF_LAB=0
