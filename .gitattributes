# Line-ending policy for VulnForge.
# Force LF in the repo AND the working copy for all text files, regardless of
# anyone's local core.autocrlf. This keeps the Makefile and shell scripts
# Linux/Docker-safe and silences the "LF will be replaced by CRLF" warnings on
# Windows.
* text=auto eol=lf

# Windows batch files must keep CRLF to run correctly.
*.bat text eol=crlf

# Binary assets - never normalize line endings.
*.png  binary
*.ico  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.woff  binary
*.woff2 binary
